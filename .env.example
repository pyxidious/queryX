APP_NAME=QueryX
LOG_LEVEL=INFO

MYSQL_ROOT_PASSWORD=queryx_root_password
MYSQL_DATABASE=queryx_demo
MYSQL_USER=queryx
MYSQL_PASSWORD=queryx_password
MYSQL_URL=mysql+pymysql://queryx:queryx_password@mysql:3306/queryx_demo
MYSQL_SOURCE_ID=mysql
MYSQL_SOURCE_NAME=Demo MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ENABLED=true

MONGO_INITDB_ROOT_USERNAME=queryx
MONGO_INITDB_ROOT_PASSWORD=queryx_password
MONGODB_USER=queryx
MONGODB_PASSWORD=queryx_password
MONGODB_URL=mongodb://queryx:queryx_password@mongodb:27017/queryx_demo?authSource=admin
MONGODB_SOURCE_ID=mongodb
MONGODB_SOURCE_NAME=Demo MongoDB
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=queryx_demo
MONGODB_ENABLED=true

CATALOG_DB_PATH=/app/data/queryx_catalog.sqlite3
DATA_RAW_DIR=/app/data/raw
DATA_STAGING_DIR=/app/data/staging
DATA_NORMALIZED_DIR=/app/data/normalized
INGESTION_MAX_UPLOAD_BYTES=26214400
INGESTION_PREVIEW_ROWS=10
INGESTION_INSPECTION_ROWS=100
INGESTION_CSV_COUNT_ROWS=10000
INGESTION_STALE_JOB_SECONDS=300
DUCKDB_PATH=/app/data/queryx.duckdb
DUCKDB_SCHEMA=queryx_managed
PROCESSING_PREVIEW_ROWS=10
PROCESSING_STALE_RUN_SECONDS=300
PARQUET_COMPRESSION=zstd
PARQUET_BATCH_ROWS=10000
QUERYX_EXECUTION_MODE=worker
WORKER_POLL_SECONDS=1
WORKER_LEASE_SECONDS=60
WORKER_HEARTBEAT_SECONDS=10
WORKER_MAX_ATTEMPTS=3
WORKER_RETRY_BASE_SECONDS=2
WORKER_RECONCILE_SECONDS=60
# WORKER_ID=queryx-worker-1
WORKER_SHUTDOWN_SECONDS=30
DUCKDB_LOCK_PATH=/app/data/queryx.duckdb.lock
DUCKDB_LOCK_TIMEOUT_SECONDS=5
QUERY_DEFAULT_LIMIT=100
QUERY_MAX_LIMIT=1000
QUERY_TIMEOUT_SECONDS=10
QUERYX_UI_ENABLED=true
# Replace locally; this placeholder is not a production secret.
QUERYX_UI_SECRET_KEY=change-this-queryx-ui-secret
QUERYX_UI_MAX_PREVIEW_COLUMNS=50
MONGO_SAMPLE_SIZE=25
CONNECTION_TIMEOUT_SECONDS=3
PROFILING_ENABLED=true
PROFILING_MAX_RECORDS_PER_ENTITY=25
PROFILING_MAX_SECONDS_PER_ENTITY=2
PROFILING_MAX_ENTITIES=100
PROFILING_MAX_TOTAL_RECORDS=500

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0
OLLAMA_THINK=false
OLLAMA_KEEP_ALIVE=10m
QUERYX_ENRICHMENT_MAX_ENTITIES=50
QUERYX_ENRICHMENT_MAX_FIELDS_PER_REQUEST=40
QUERYX_ENRICHMENT_MAX_RETRIES=1
QUERYX_ENRICHMENT_MAX_PROMPT_CHARS=12000

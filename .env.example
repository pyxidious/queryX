APP_NAME=QueryX
LOG_LEVEL=INFO

MYSQL_ROOT_PASSWORD=queryx_root_password
MYSQL_DATABASE=queryx_demo
MYSQL_USER=queryx
MYSQL_PASSWORD=queryx_password
MYSQL_URL=mysql+pymysql://queryx:queryx_password@mysql:3306/queryx_demo
MYSQL_SOURCE_ID=mysql
MYSQL_SOURCE_NAME=Demo MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ENABLED=true

MONGO_INITDB_ROOT_USERNAME=queryx
MONGO_INITDB_ROOT_PASSWORD=queryx_password
MONGODB_USER=queryx
MONGODB_PASSWORD=queryx_password
MONGODB_URL=mongodb://queryx:queryx_password@mongodb:27017/queryx_demo?authSource=admin
MONGODB_SOURCE_ID=mongodb
MONGODB_SOURCE_NAME=Demo MongoDB
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=queryx_demo
MONGODB_ENABLED=true

CATALOG_DB_PATH=/app/data/queryx_catalog.sqlite3
MONGO_SAMPLE_SIZE=25
CONNECTION_TIMEOUT_SECONDS=3
PROFILING_ENABLED=true
PROFILING_MAX_RECORDS_PER_ENTITY=25
PROFILING_MAX_SECONDS_PER_ENTITY=2
PROFILING_MAX_ENTITIES=100
PROFILING_MAX_TOTAL_RECORDS=500

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0
OLLAMA_THINK=false
OLLAMA_KEEP_ALIVE=10m
QUERYX_ENRICHMENT_MAX_ENTITIES=50
QUERYX_ENRICHMENT_MAX_FIELDS_PER_REQUEST=40
QUERYX_ENRICHMENT_MAX_RETRIES=1
QUERYX_ENRICHMENT_MAX_PROMPT_CHARS=12000
